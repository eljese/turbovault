# Global ignores
__pycache__/
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.pyc
*.pyo
*.pyd
.coverage
htmlcov/
.DS_Store

# Environment
.env
.env.*
!.env.example

# Private strategy docs (keep untracked)
.strategy/
**/PRIVATE_*.md
**/*_CONFIDENTIAL.md
**/monetization*.md

/target*

# Exclude markdown files EXCEPT for documentation and README files
*.md
!README.md
!docs/**/*.md
!CHANGELOG.md
!RELEASE*.md
!PUBLISH*.md
!/LICENSE*
!LICENSE

# IDEs and Tools
.gemini/
.vscode/
.idea/
.cursor/
*.swp
*.swo

# Local Configuration
config.yaml
docker-compose.yml

# Build & Temporary
node_modules/
mcp_requests.json
graph_debug.log
*.tmp
shim.js
nginx/
